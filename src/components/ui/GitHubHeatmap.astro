---
import {
    fetchContributionStats,
    calculateStreaks,
    GITHUB_USERNAME_EXPORT,
} from "@/lib/github";
import LanguageChart from "./LanguageChart.astro";

const data = await fetchContributionStats();
const weeks = data?.weeks ?? [];
const total = data?.totalContributions ?? 0;
const streaks = calculateStreaks(weeks);

const summary = [
    { value: total.toLocaleString(), label: "Contributions / yr" },
    { value: `${streaks.current}`, label: "Current streak", accent: true },
    { value: `${streaks.longest}`, label: "Longest streak" },
    { value: `${Math.round(total / 52)}`, label: "Avg / week" },
];

function heatVar(count: number): string {
    if (count === 0) return "var(--heat-0)";
    if (count <= 2) return "var(--heat-1)";
    if (count <= 5) return "var(--heat-2)";
    if (count <= 8) return "var(--heat-3)";
    return "var(--heat-4)";
}

const CELL = 13;
const GAP = 3;
const STEP = CELL + GAP;
---

{weeks.length > 0 && (
    <section id="activity" class="section section-border gh-heat">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Activity</p>
                    <h2 class="section-title">Still shipping,<br />every week.</h2>
                </div>
                <a
                    class="hidden md:inline-flex font-mono text-xs uppercase tracking-[0.2em] text-[var(--ink-secondary)] transition-colors hover:text-[var(--accent)]"
                    href={`https://github.com/${GITHUB_USERNAME_EXPORT}`}
                    target="_blank"
                    rel="noreferrer"
                >@{GITHUB_USERNAME_EXPORT} ↗</a>
            </div>

            <div class="mt-12 grid grid-cols-2 gap-8 md:grid-cols-4" data-stagger>
                {summary.map((s) => (
                    <div class="stat-block">
                        <p class="stat-value" style={s.accent ? "color: var(--accent)" : ""}>{s.value}</p>
                        <p class="stat-label">{s.label}</p>
                    </div>
                ))}
            </div>

            <div class="mt-12 overflow-x-auto pb-2">
                <svg
                    width={weeks.length * STEP}
                    height={7 * STEP}
                    role="img"
                    aria-label={`${total} GitHub contributions over the last year`}
                >
                    {weeks.map((week, w) => (
                        <g transform={`translate(${w * STEP}, 0)`}>
                            {week.contributionDays.map((day, d) => (
                                <rect
                                    x="0"
                                    y={d * STEP}
                                    width={CELL}
                                    height={CELL}
                                    rx="2.5"
                                    class="gh-cell"
                                    style={`fill: ${heatVar(day.contributionCount)}`}
                                >
                                    <title>{day.date}: {day.contributionCount} contribution{day.contributionCount === 1 ? "" : "s"}</title>
                                </rect>
                            ))}
                        </g>
                    ))}
                </svg>
            </div>

            <div class="mt-4 flex items-center justify-end gap-2 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--ink-muted)]" data-reveal>
                <span>Less</span>
                {["var(--heat-0)", "var(--heat-1)", "var(--heat-2)", "var(--heat-3)", "var(--heat-4)"].map((c) => (
                    <span class="h-3 w-3 rounded-[2px]" style={`background: ${c}`}></span>
                ))}
                <span>More</span>
            </div>

            <LanguageChart />
        </div>
    </section>
)}

<style>
    .gh-heat {
        --heat-0: var(--bg-muted);
        --heat-1: color-mix(in srgb, var(--accent) 28%, var(--bg-muted));
        --heat-2: color-mix(in srgb, var(--accent) 52%, var(--bg-muted));
        --heat-3: color-mix(in srgb, var(--accent) 76%, var(--bg-muted));
        --heat-4: var(--accent);
    }
    .gh-heat rect {
        transition: opacity 0.15s ease;
    }
    .gh-cell {
        transform-box: fill-box;
        transform-origin: center;
    }
    .gh-heat svg:hover rect {
        opacity: 0.55;
    }
    .gh-heat svg rect:hover {
        opacity: 1;
        stroke: var(--ink);
        stroke-width: 1;
    }
</style>
