---
import { fetchLanguageDistribution } from "@/lib/github";

const languages = await fetchLanguageDistribution();
---

{languages.length > 0 && (
    <div class="mt-16" data-reveal>
        <p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--ink-muted)] mb-5">
            Language footprint
        </p>

        <div class="flex h-3 w-full overflow-hidden rounded-full border" style="border-color: var(--line);">
            {languages.map((lang) => (
                <div
                    style={`width: ${lang.percentage}%; background-color: ${lang.color};`}
                    title={`${lang.name}: ${lang.percentage}%`}
                ></div>
            ))}
        </div>

        <div class="mt-5 flex flex-wrap gap-x-6 gap-y-2">
            {languages.map((lang) => (
                <span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.12em] text-[var(--ink-secondary)]">
                    <span class="h-2.5 w-2.5 rounded-full" style={`background-color: ${lang.color};`}></span>
                    {lang.name}
                    <span class="text-[var(--ink-muted)]">{lang.percentage}%</span>
                </span>
            ))}
        </div>
    </div>
)}
