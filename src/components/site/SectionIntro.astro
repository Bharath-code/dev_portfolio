---
interface Props {
    eyebrow?: string;
    title: string;
    description?: string;
    align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const alignmentClass =
    align === "center"
        ? "mx-auto max-w-3xl text-center items-center"
        : "max-w-3xl";
---

<div class:list={["section-intro", alignmentClass]}>
    {eyebrow && <p class="section-kicker">{eyebrow}</p>}
    <h2 class="section-title">{title}</h2>
    {description && <p class="section-copy">{description}</p>}
</div>
