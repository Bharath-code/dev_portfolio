---
import type { MappedBook } from "@/lib/books";

interface Props {
    book: MappedBook;
}

const { book } = Astro.props;
const isRead = book.status === "read";
const filled = "★".repeat(book.rating);
const empty = "★".repeat(Math.max(0, 5 - book.rating));
---

<article class="book-card">
    <div class="flex items-start justify-between gap-3">
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--accent-text)]">{book.genre}</p>
        <span class:list={["book-badge", isRead ? "is-read" : "is-queued"]}>
            {isRead ? "Read" : "On the list"}
        </span>
    </div>

    <h3 class="mt-3 font-display text-lg uppercase leading-tight md:text-xl">{book.title}</h3>
    <p class="mt-2 font-mono text-xs uppercase tracking-[0.14em] text-[var(--ink-muted)]">{book.author}</p>

    {book.review && <p class="mb-5 mt-4 text-sm leading-6 text-[var(--ink-secondary)]">{book.review}</p>}

    <div class="mt-auto flex items-center justify-between gap-4 border-t pt-4" style="border-color: var(--line);">
        {isRead && book.rating > 0 ? (
            <span class="book-stars" aria-label={`Rated ${book.rating} out of 5`}>
                {filled}<span class="dim">{empty}</span>
            </span>
        ) : (
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--ink-muted)]">
                {isRead ? "Finished" : "Want to read"}
            </span>
        )}
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--ink-muted)]">
            {book.pages ? `${book.pages} pages` : ""}{book.pages && isRead && book.year ? " · " : ""}{isRead && book.year ? book.year : ""}
        </span>
    </div>
</article>
