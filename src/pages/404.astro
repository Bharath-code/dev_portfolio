---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="404 | Bharathkumar Palanisamy">
    <section class="section-shell">
        <div class="shell">
            <article class="surface-card-dark mx-auto max-w-4xl text-center">
                <p class="section-kicker text-[#cfb7a6]">404</p>
                <h1 class="font-serif text-[4rem] leading-none md:text-[7rem]">
                    This page isn’t part of the portfolio.
                </h1>
                <p class="mx-auto mt-6 max-w-2xl text-base leading-7 text-[#d8c8bd]">
                    The link may be outdated, incomplete, or no longer meant to
                    be public. The homepage still has the work, writing, and
                    contact details you probably wanted.
                </p>
                <div class="mt-10 flex justify-center">
                    <a class="button-primary" href="/">Return home</a>
                </div>
            </article>
        </div>
    </section>
</Layout>
