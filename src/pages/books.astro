---
import Layout from "@/layouts/Layout.astro";
import BookShelfCard from "@/components/site/BookShelfCard.astro";
import booksData from "@/data/books.json";
import { mapBooks, type RawBook } from "@/lib/books";

const books = mapBooks(booksData as RawBook[]);
// Read books first, then the reading list
books.sort((a, b) => (a.status === b.status ? 0 : a.status === "read" ? -1 : 1));

const readBooks = books.filter((book) => book.status === "read");
const queuedBooks = books.filter((book) => book.status === "reading-list");
const pagesRead = readBooks.reduce((sum, book) => sum + (book.pages || 0), 0);
const genreCount = new Set(
    booksData.flatMap((book) => (book as RawBook).Genre || []),
).size;

const stats = [
    { value: String(readBooks.length), label: "Books read" },
    { value: String(queuedBooks.length), label: "On the reading list" },
    { value: pagesRead.toLocaleString("en-US"), label: "Pages read" },
    { value: String(genreCount), label: "Genres explored" },
];

const filters = [
    { id: "all", label: `All (${books.length})` },
    { id: "read", label: `Read (${readBooks.length})` },
    { id: "reading-list", label: `Reading list (${queuedBooks.length})` },
];
---

<Layout
    title="Library | Bharathkumar Palanisamy"
    description="69 finished books on software, business, and behavior — the inputs behind the engineering judgment."
>
    <section class="section pt-16 md:pt-20">
        <div class="layout-shell">
            <p class="section-eyebrow fade-up">Library · Synced from Notion</p>
            <h1 class="mt-6 font-display text-4xl uppercase leading-[0.96] sm:text-6xl md:text-7xl fade-up fade-delay-1">
                Books I've<br />read<span class="text-[var(--accent)]">.</span>
            </h1>
            <p class="mt-8 max-w-2xl text-lg leading-8 text-[var(--ink-secondary)] fade-up fade-delay-2">
                Reading is part of how I sharpen judgment, not just collect ideas.
                This shelf spans software, business, and behavior — the finished
                reads plus what's queued next. Because the best engineering
                decisions usually borrow from more than engineering.
            </p>

            <div class="hero-rule mt-14 fade-up fade-delay-2"></div>

            <div class="mt-10 grid grid-cols-2 gap-8 md:grid-cols-4 fade-up fade-delay-3">
                {stats.map((stat) => (
                    <div class="stat-block">
                        <p class="stat-value">{stat.value}</p>
                        <p class="stat-label">{stat.label}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="section section-border pt-14 md:pt-16">
        <div class="layout-shell space-y-10">
            <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex flex-wrap gap-2">
                    {filters.map((filter) => (
                        <button
                            class:list={[
                                "filter-button",
                                filter.id === "all" ? "button-primary" : "button-secondary",
                            ]}
                            data-filter={filter.id}
                            data-active={filter.id === "all" ? "true" : "false"}
                            type="button"
                        >
                            {filter.label}
                        </button>
                    ))}
                </div>
                <div class="grid w-full gap-3 sm:w-auto sm:grid-cols-2">
                    <input
                        id="book-search"
                        type="search"
                        placeholder="Search title or author"
                        class="input-dark sm:w-64"
                    />
                    <select id="book-sort" class="input-dark">
                        <option value="default">Default sort</option>
                        <option value="rating">Top rated</option>
                        <option value="title">Title</option>
                        <option value="year">Recent first</option>
                    </select>
                </div>
            </div>

            <div id="books-grid" class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
                {books.map((book, index) => (
                    <div
                        class="book-item"
                        data-index={index}
                        data-status={book.status}
                        data-title={book.title.toLowerCase()}
                        data-author={book.author.toLowerCase()}
                        data-rating={book.rating}
                        data-year={book.year || 0}
                    >
                        <BookShelfCard book={book} />
                    </div>
                ))}
            </div>

            <div
                id="no-results"
                class="hidden rounded-[var(--radius-sm)] border px-6 py-16 text-center"
                style="border-color: var(--line); background: var(--bg-elevated);"
            >
                <p class="font-display text-2xl uppercase">No matching books<span class="text-[var(--accent)]">.</span></p>
                <p class="mt-3 font-mono text-xs uppercase tracking-[0.16em] text-[var(--ink-muted)]">
                    Reset the filters or try a different search
                </p>
            </div>
        </div>
    </section>
</Layout>

<script>
    function initLibraryFilters() {
        const searchInput = document.getElementById("book-search");
        const sortSelect = document.getElementById("book-sort");
        const buttons = Array.from(
            document.querySelectorAll(".filter-button"),
        );
        const items = Array.from(document.querySelectorAll(".book-item"));
        const grid = document.getElementById("books-grid");
        const noResults = document.getElementById("no-results");

        if (!grid || !noResults || !searchInput || !sortSelect || items.length === 0) {
            return;
        }

        let activeFilter = "all";
        let query = "";
        let activeSort = "default";

        function applyState() {
            const visibleItems = [];

            for (const item of items) {
                const status = item.getAttribute("data-status") || "";
                const title = item.getAttribute("data-title") || "";
                const author = item.getAttribute("data-author") || "";
                const matchesFilter = activeFilter === "all" || status === activeFilter;
                const matchesQuery = title.includes(query) || author.includes(query);
                const visible = matchesFilter && matchesQuery;

                item.toggleAttribute("hidden", !visible);
                if (visible) visibleItems.push(item);
            }

            const sortedItems = [...visibleItems].sort((a, b) => {
                if (activeSort === "rating") {
                    return Number(b.getAttribute("data-rating")) - Number(a.getAttribute("data-rating"));
                }

                if (activeSort === "title") {
                    return (a.getAttribute("data-title") || "").localeCompare(
                        b.getAttribute("data-title") || "",
                    );
                }

                if (activeSort === "year") {
                    return Number(b.getAttribute("data-year")) - Number(a.getAttribute("data-year"));
                }

                return Number(a.getAttribute("data-index")) - Number(b.getAttribute("data-index"));
            });

            sortedItems.forEach((item) => grid.appendChild(item));

            noResults.classList.toggle("hidden", visibleItems.length > 0);
            grid.classList.toggle("hidden", visibleItems.length === 0);
        }

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                activeFilter = button.getAttribute("data-filter") || "all";
                buttons.forEach((candidate) => {
                    const isActive = candidate === button;
                    candidate.setAttribute("data-active", isActive ? "true" : "false");
                    candidate.classList.toggle("button-primary", isActive);
                    candidate.classList.toggle("button-secondary", !isActive);
                });
                applyState();
            });
        });

        searchInput.addEventListener("input", (event) => {
            const target = event.currentTarget as HTMLInputElement;
            query = target.value.trim().toLowerCase();
            applyState();
        });

        sortSelect.addEventListener("change", (event) => {
            const target = event.currentTarget as HTMLSelectElement;
            activeSort = target.value;
            applyState();
        });
    }

    initLibraryFilters();
</script>
