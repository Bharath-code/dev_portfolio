---
import Layout from "@/layouts/Layout.astro";
import SectionIntro from "@/components/site/SectionIntro.astro";
import BookShelfCard from "@/components/site/BookShelfCard.astro";
import booksData from "@/data/books.json";
import { mapBooks, type RawBook } from "@/lib/books";

const books = mapBooks(booksData as RawBook[]);
const stats = {
    total: books.length,
    recommended: books.filter((book) => book.status === "recommended").length,
    finished: books.filter((book) => book.status === "read").length,
    queue: books.filter((book) => book.status === "want-to-read").length,
};

const categories = [
    { id: "all", label: "All" },
    { id: "recommended", label: "Recommended" },
    { id: "read", label: "Finished" },
    { id: "want-to-read", label: "Reading list" },
];
---

<Layout
    title="Library | Bharathkumar Palanisamy"
    description="A curated library of books that shape Bharathkumar Palanisamy's thinking on software, business, and behavior."
>
    <section class="section-shell">
        <div class="shell space-y-10">
            <SectionIntro
                eyebrow="Library"
                title="Reading is part of how I sharpen judgment, not just how I collect ideas."
                description="This shelf spans software, business, behavior, and adjacent fields. It’s here because the best engineering decisions usually borrow from more than engineering."
            />

            <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                <article class="metric-card">
                    <strong>{stats.total}</strong>
                    <span>Total books tracked</span>
                    <p>A living archive rather than a decorative reading list.</p>
                </article>
                <article class="metric-card">
                    <strong>{stats.recommended}</strong>
                    <span>Strong recommendations</span>
                    <p>Books I would gladly point a colleague toward.</p>
                </article>
                <article class="metric-card">
                    <strong>{stats.finished}</strong>
                    <span>Finished reads</span>
                    <p>Completed books that actively shaped my thinking.</p>
                </article>
                <article class="metric-card">
                    <strong>{stats.queue}</strong>
                    <span>Still in queue</span>
                    <p>Future inputs for better systems and better choices.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section-shell-tight section-surface">
        <div class="shell space-y-8">
            <div class="grid gap-4 xl:grid-cols-[1fr_auto_auto] xl:items-center">
                <div class="surface-card">
                    <p class="card-kicker">Discovery controls</p>
                    <p class="card-copy">
                        Filter by recommendation status, search by title or
                        author, or sort for quick scanning.
                    </p>
                </div>

                <div class="flex flex-wrap gap-2">
                    {categories.map((category) => (
                        <button
                            class:list={[
                                "filter-button",
                                category.id === "all"
                                    ? "button-primary"
                                    : "button-secondary",
                            ]}
                            data-filter={category.id}
                            data-active={category.id === "all" ? "true" : "false"}
                            type="button"
                        >
                            {category.label}
                        </button>
                    ))}
                </div>

                <div class="grid gap-3 sm:grid-cols-2">
                    <input
                        id="book-search"
                        type="search"
                        placeholder="Search title or author"
                        class="rounded-full border border-[var(--line)] bg-[var(--bg-elevated)] px-4 py-3 text-sm text-[var(--ink)] outline-none transition focus:border-[var(--accent)]"
                    />
                    <select
                        id="book-sort"
                        class="rounded-full border border-[var(--line)] bg-[var(--bg-elevated)] px-4 py-3 text-sm text-[var(--ink)] outline-none transition focus:border-[var(--accent)]"
                    >
                        <option value="default">Default sort</option>
                        <option value="rating">Top rated</option>
                        <option value="title">Title</option>
                        <option value="year">Recent first</option>
                    </select>
                </div>
            </div>

            <div id="books-grid" class="grid gap-6 lg:grid-cols-2">
                {books.map((book, index) => (
                    <div
                        class="book-item"
                        data-index={index}
                        data-status={book.status}
                        data-title={book.title.toLowerCase()}
                        data-author={book.author.toLowerCase()}
                        data-rating={book.rating}
                        data-year={book.year || 0}
                    >
                        <BookShelfCard book={book} />
                    </div>
                ))}
            </div>

            <div
                id="no-results"
                class="hidden rounded-[32px] border border-[var(--line)] bg-[var(--bg-elevated)] px-6 py-16 text-center"
            >
                <p class="font-serif text-3xl">No matching books found.</p>
                <p class="mt-3 text-sm text-[var(--muted)]">
                    Reset the filters or try a different search query.
                </p>
            </div>
        </div>
    </section>
</Layout>

<script>
    function initLibraryFilters() {
        const searchInput = document.getElementById("book-search");
        const sortSelect = document.getElementById("book-sort");
        const buttons = Array.from(
            document.querySelectorAll(".filter-button"),
        );
        const items = Array.from(document.querySelectorAll(".book-item"));
        const grid = document.getElementById("books-grid");
        const noResults = document.getElementById("no-results");

        if (!grid || !noResults || !searchInput || !sortSelect || items.length === 0) {
            return;
        }

        let activeFilter = "all";
        let query = "";
        let activeSort = "default";

        function applyState() {
            const visibleItems = [];

            for (const item of items) {
                const status = item.getAttribute("data-status") || "";
                const title = item.getAttribute("data-title") || "";
                const author = item.getAttribute("data-author") || "";
                const matchesFilter = activeFilter === "all" || status === activeFilter;
                const matchesQuery = title.includes(query) || author.includes(query);
                const visible = matchesFilter && matchesQuery;

                item.toggleAttribute("hidden", !visible);
                if (visible) visibleItems.push(item);
            }

            const sortedItems = [...visibleItems].sort((a, b) => {
                if (activeSort === "rating") {
                    return Number(b.getAttribute("data-rating")) - Number(a.getAttribute("data-rating"));
                }

                if (activeSort === "title") {
                    return (a.getAttribute("data-title") || "").localeCompare(
                        b.getAttribute("data-title") || "",
                    );
                }

                if (activeSort === "year") {
                    return Number(b.getAttribute("data-year")) - Number(a.getAttribute("data-year"));
                }

                return Number(a.getAttribute("data-index")) - Number(b.getAttribute("data-index"));
            });

            sortedItems.forEach((item) => grid.appendChild(item));

            noResults.classList.toggle("hidden", visibleItems.length > 0);
            grid.classList.toggle("hidden", visibleItems.length === 0);
        }

        buttons.forEach((button) => {
            button.addEventListener("click", () => {
                activeFilter = button.getAttribute("data-filter") || "all";
                buttons.forEach((candidate) => {
                    const isActive = candidate === button;
                    candidate.setAttribute("data-active", isActive ? "true" : "false");
                    candidate.classList.toggle("button-primary", isActive);
                    candidate.classList.toggle("button-secondary", !isActive);
                });
                applyState();
            });
        });

        searchInput.addEventListener("input", (event) => {
            const target = event.currentTarget as HTMLInputElement;
            query = target.value.trim().toLowerCase();
            applyState();
        });

        sortSelect.addEventListener("change", (event) => {
            const target = event.currentTarget as HTMLSelectElement;
            activeSort = target.value;
            applyState();
        });
    }

    initLibraryFilters();
</script>
