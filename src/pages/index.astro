---
import Layout from "@/layouts/Layout.astro";
import content from "@/data/site-content.json";
import { getLatestPosts } from "@/lib/blog";
import { fetchRepoStatsByUrls } from "@/lib/github";
import GitHubHeatmap from "@/components/ui/GitHubHeatmap.astro";

const posts = await getLatestPosts(content.blogConfig, 4);

// Live GitHub stars at build time; falls back to JSON values when GITHUB_TOKEN is absent.
const repoStats = await fetchRepoStatsByUrls(
    content.projects.map((p) => p.link).filter(Boolean) as string[],
);

const repoKey = (url?: string) =>
    url?.match(/github\.com\/[^/]+\/([^/]+)/)?.[1]?.replace(/\.git$/, "").toLowerCase() ?? null;

const liveMetrics = (project: (typeof content.projects)[number]) => {
    const live = repoStats.get(repoKey(project.link) ?? "");
    if (!live) return project.metrics;
    return project.metrics.map((m) =>
        /stars?/i.test(m.label) ? { ...m, value: String(live.stargazerCount) } : m,
    );
};

const gitScopeStars = repoStats.get("git-scope")?.stargazerCount;

const marqueeItems = [
    "React 19",
    "TypeScript",
    "Next.js",
    "AI Agents",
    "RAG",
    "Tool Calling",
    "GSAP",
    "Astro",
    "Svelte 5",
    "Go",
    "LLM Guardrails",
    "Developer Tools",
];

const stats = [
    { value: 30, suffix: "+", label: "Products shipped" },
    { value: gitScopeStars ?? 98, suffix: gitScopeStars ? "" : "+", label: "GitHub stars · git-scope" },
    { value: 3, suffix: "", label: "npm packages published" },
    { value: 10, suffix: "+", label: "Years building" },
];
---

<Layout title="Bharathkumar Palanisamy | Frontend Engineer · AI-Integrated Products">
    <!-- LOADER -->
    <div id="loader" class="loader" aria-hidden="true">
        <span id="loader-count" class="loader-count font-mono">0</span>
    </div>
    <noscript><style>#loader { display: none; }</style></noscript>
    <script is:inline>
        (function () {
            var loader = document.getElementById("loader");
            var countEl = document.getElementById("loader-count");
            var html = document.documentElement;
            var reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;

            if (reduced) {
                if (loader) loader.remove();
                window.__introDone = true;
                return;
            }

            html.classList.add("intro-active");

            var start;
            function tick(now) {
                if (!start) start = now;
                var p = Math.min((now - start) / 450, 1);
                var eased = 1 - Math.pow(1 - p, 3);
                if (countEl) countEl.textContent = Math.round(eased * 100);
                if (p < 1) {
                    requestAnimationFrame(tick);
                } else {
                    if (loader) loader.classList.add("loader-wipe");
                    setTimeout(function () {
                        window.__introDone = true;
                        if (window.__playHero) window.__playHero();
                        else html.classList.remove("intro-active");
                        if (loader) loader.remove();
                    }, 400);
                }
            }
            requestAnimationFrame(tick);
        })();
    </script>

    <!-- HERO -->
    <section class="section pt-16 md:pt-24">
        <div class="layout-shell">
            <div class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.22em] text-[var(--ink-secondary)] hero-fade">
                <span class="inline-flex h-2 w-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
                {content.availability.status} · {content.availability.location}
            </div>

            <div class="mt-10 grid gap-12 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
                <div>
                    <h1>
                        <span class="mask block"><span class="hero-display hero-line block">Frontend</span></span>
                        <span class="mask block"><span class="hero-display hero-line block">Engineer<span class="text-[var(--accent)]">.</span></span></span>
                        <span class="mask block mt-4"><span class="hero-serif hero-line block text-3xl sm:text-4xl md:text-5xl">building AI-integrated products that ship.</span></span>
                    </h1>

                    <p class="mt-10 max-w-xl text-lg leading-8 text-[var(--ink-secondary)] hero-fade">
                        {content.hero.bio}
                    </p>
                    <div class="mt-8 flex flex-wrap gap-3 hero-fade">
                        <a class="button-primary" href={content.hero.cta.primary.href} data-magnetic>
                            {content.hero.cta.primary.label}
                        </a>
                        <a class="button-secondary" href={content.hero.cta.secondary.href} data-magnetic>
                            {content.hero.cta.secondary.label}
                        </a>
                    </div>
                </div>

                <div class="hero-photo hero-fade">
                    <div class="hero-photo-frame">
                        <img
                            src="/profile-pic-2.png"
                            alt="Bharathkumar Palanisamy"
                            width="320"
                            height="400"
                            loading="eager"
                        />
                        <p class="hero-photo-tag">
                            <span>Bharathkumar</span>
                            <span class="acc">●</span>
                            <span>EST. 2015</span>
                        </p>
                    </div>
                </div>
            </div>

            <div class="hero-rule mt-16 hero-fade"></div>

            <div class="mt-10 grid grid-cols-2 gap-8 md:grid-cols-4" data-stagger>
                {stats.map((stat) => (
                    <div class="stat-block">
                        <p class="stat-value">
                            <span data-count={stat.value}>{stat.value}</span><span class="acc">{stat.suffix}</span>
                        </p>
                        <p class="stat-label">{stat.label}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- MARQUEE -->
    <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
            {[0, 1].map(() => (
                <>
                    {marqueeItems.map((item) => (
                        <>
                            <span>{item}</span>
                            <span class="acc">✦</span>
                        </>
                    ))}
                </>
            ))}
        </div>
    </div>

    <!-- WORK -->
    <section id="work" class="section">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Selected work</p>
                    <h2 class="section-title">Built, shipped,<br />maintained.</h2>
                </div>
                <span class="section-index hidden md:block">01</span>
            </div>

            <div class="mt-14">
                {content.projects.map((project, i) => (
                    <a class="project-row" href={`/projects/${project.slug}`} data-reveal>
                        <span class="project-row-index">{String(i + 1).padStart(2, "0")}</span>
                        <div class="space-y-3">
                            <h3 class="project-row-title">{project.title}</h3>
                            <p class="max-w-md text-sm leading-6 text-[var(--ink-secondary)]">{project.description}</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex flex-wrap gap-1.5">
                                {project.tags.map((tag) => (
                                    <span class="pill">{tag}</span>
                                ))}
                            </div>
                            <p class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--ink-muted)]">
                                {liveMetrics(project).map((m) => `${m.value} ${m.label}`).join(" · ")}
                            </p>
                        </div>
                        <span class="project-row-arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                        </span>
                    </a>
                ))}
            </div>

            <div class="mt-20" data-reveal>
                <p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--ink-muted)] mb-6">More builds</p>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4" data-stagger>
                    {content.secondaryProjects.map((project) => (
                        <a class="mini-card group" href={project.href} target="_blank" rel="noreferrer">
                            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--accent-text)]">{project.category}</p>
                            <h3 class="mt-3 font-display text-base uppercase group-hover:text-[var(--accent)] transition-colors">{project.title}</h3>
                            <p class="mt-2 text-sm leading-6 text-[var(--ink-secondary)]">{project.summary}</p>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="section section-border">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Capabilities</p>
                    <h2 class="section-title">What I<br />work with.</h2>
                    <p class="section-copy">
                        Deep frontend craft, hands-on AI engineering, and enough backend to ship complete products end-to-end.
                    </p>
                </div>
                <span class="section-index hidden md:block">02</span>
            </div>

            <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
                {content.skillCategories.map((category) => (
                    <div class="skill-block">
                        <h3 class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-[var(--ink)]">{category.title}</h3>
                        <ul class="mt-5">
                            {category.tags.map((tag) => (
                                <li class="skill-tag">{tag}</li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="section section-border">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Experience</p>
                    <h2 class="section-title">Where I've<br />shipped.</h2>
                </div>
                <span class="section-index hidden md:block">03</span>
            </div>

            <div class="mt-14">
                {content.experience.map((item) => (
                    <div class="xp-row" data-reveal>
                        <p class="xp-period">{item.period}</p>
                        <div>
                            <h3 class="xp-company">{item.company}</h3>
                            <p class="xp-role">{item.role}</p>
                            <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[var(--ink-secondary)]">{item.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- ACTIVITY -->
    <GitHubHeatmap />

    <!-- WRITING -->
    {posts.length > 0 && (
        <section id="writing" class="section section-border">
            <div class="layout-shell">
                <div class="flex items-end justify-between gap-6" data-reveal>
                    <div>
                        <p class="section-eyebrow">Writing</p>
                        <h2 class="section-title">Notes from<br />the build.</h2>
                    </div>
                    <span class="section-index hidden md:block">04</span>
                </div>

                <div class="mt-14">
                    {posts.map((post) => (
                        <a class="post-row" href={post.url} target="_blank" rel="noreferrer" data-reveal>
                            <p class="post-row-date">{post.date}</p>
                            <h3 class="post-row-title">{post.title}</h3>
                            <span class="pill">{post.platform}</span>
                        </a>
                    ))}
                </div>

                <div class="mt-10" data-reveal>
                    <a class="link-arrow" href="/blog">
                        All writing
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                </div>
            </div>
        </section>
    )}

    <!-- CONTACT -->
    <section id="contact" class="section section-border">
        <div class="layout-shell">
            <p class="section-eyebrow" data-reveal>{content.availability.status} · {content.availability.roles.join(" / ")}</p>
            <h2 class="contact-display mt-8" data-reveal>
                Let's ship<br />something<span class="text-[var(--accent)]">.</span>
            </h2>
            <div class="mt-10" data-reveal>
                <a class="contact-email" href={`mailto:${content.contact.email}`}>
                    {content.contact.email}
                </a>
            </div>
            <div class="mt-14 flex flex-wrap items-center gap-6" data-reveal>
                <a
                    class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--accent-text)] transition-colors hover:text-[var(--accent)]"
                    href="/Bharathkumar_Resume.pdf"
                    download="Bharathkumar-Palanisamy-Resume.pdf"
                >
                    Résumé (PDF) ↓
                </a>
                {content.contact.socials.map((social) => (
                    <a
                        class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--ink-secondary)] transition-colors hover:text-[var(--accent)]"
                        href={social.href}
                        target="_blank"
                        rel="noreferrer"
                    >
                        {social.label} ↗
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function playHero() {
        gsap.timeline({ defaults: { ease: "power3.out" } })
            .from(".hero-line", { yPercent: 110, duration: 0.9, stagger: 0.12 })
            .from(".hero-fade", { y: 24, autoAlpha: 0, duration: 0.7, stagger: 0.1 }, "-=0.45");
        document.documentElement.classList.remove("intro-active");
    }

    function setupScroll() {
        document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
            const target = Number(el.dataset.count);
            gsap.fromTo(
                el,
                { textContent: 0 },
                {
                    textContent: target,
                    duration: 1.4,
                    ease: "power1.out",
                    snap: { textContent: 1 },
                    scrollTrigger: { trigger: el, start: "top 90%" },
                },
            );
        });

        gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((el) => {
            gsap.from(el, {
                y: 36,
                opacity: 0.25,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: { trigger: el, start: "top 88%" },
            });
        });

        gsap.utils.toArray<HTMLElement>("[data-stagger]").forEach((group) => {
            gsap.from(group.children, {
                y: 24,
                opacity: 0.25,
                duration: 0.6,
                stagger: 0.08,
                ease: "power2.out",
                scrollTrigger: { trigger: group, start: "top 88%" },
            });
        });

        // Heatmap cells pop in as a diagonal wave on scroll.
        const cells = gsap.utils.toArray<SVGRectElement>(".gh-cell");
        if (cells.length) {
            gsap.from(cells, {
                scale: 0,
                autoAlpha: 0,
                duration: 0.4,
                ease: "back.out(1.7)",
                immediateRender: false,
                stagger: { each: 0.0025, from: "start" },
                scrollTrigger: { trigger: "#activity", start: "top 75%" },
            });
        }

        // Marquee reacts to scroll velocity, then settles back.
        const mq = gsap.to(".marquee-track", { xPercent: -50, ease: "none", duration: 28, repeat: -1 });
        let settle: ReturnType<typeof gsap.delayedCall> | null = null;
        ScrollTrigger.create({
            onUpdate: (self) => {
                const dir = self.direction || 1;
                const speed = gsap.utils.clamp(1, 6, 1 + Math.abs(self.getVelocity()) / 300);
                gsap.to(mq, { timeScale: dir * speed, duration: 0.25, overwrite: true });
                settle?.kill();
                settle = gsap.delayedCall(0.4, () =>
                    gsap.to(mq, { timeScale: 1, duration: 1, overwrite: true }),
                );
            },
        });
    }

    function setupMagnetic() {
        if (!window.matchMedia("(pointer: fine)").matches) return;
        document.querySelectorAll<HTMLElement>("[data-magnetic]").forEach((el) => {
            const xTo = gsap.quickTo(el, "x", { duration: 0.4, ease: "power3" });
            const yTo = gsap.quickTo(el, "y", { duration: 0.4, ease: "power3" });
            el.addEventListener("pointermove", (e) => {
                const r = el.getBoundingClientRect();
                xTo((e.clientX - r.left - r.width / 2) * 0.4);
                yTo((e.clientY - r.top - r.height / 2) * 0.4);
            });
            el.addEventListener("pointerleave", () => {
                xTo(0);
                yTo(0);
            });
        });
    }

    if (!reduced) {
        setupScroll();
        setupMagnetic();
    }

    // The inline script runs the loader (so it isn't blocked by this bundle).
    // Hand off the hero reveal whenever both sides are ready.
    const intro = window as typeof window & { __playHero?: () => void; __introDone?: boolean };
    intro.__playHero = playHero;
    if (intro.__introDone && document.documentElement.classList.contains("intro-active")) {
        playHero();
    }
</script>
