---
import Layout from "@/layouts/Layout.astro";
import content from "@/data/site-content.json";

const marqueeItems = [
    "React 19",
    "TypeScript",
    "Next.js",
    "AI Agents",
    "RAG",
    "Tool Calling",
    "GSAP",
    "Astro",
    "Svelte 5",
    "Go",
    "LLM Guardrails",
    "Developer Tools",
];

const stats = [
    { value: 30, suffix: "+", label: "Products shipped" },
    { value: 98, suffix: "+", label: "GitHub stars · git-scope" },
    { value: 3, suffix: "", label: "npm packages published" },
    { value: 10, suffix: "+", label: "Years building" },
];
---

<Layout title="Bharathkumar Palanisamy | Frontend Engineer · AI-Integrated Products">
    <!-- HERO -->
    <section class="section pt-16 md:pt-24">
        <div class="layout-shell">
            <div class="flex items-center gap-3 font-mono text-xs uppercase tracking-[0.22em] text-[var(--ink-secondary)] hero-fade">
                <span class="inline-flex h-2 w-2 rounded-full bg-[var(--accent)] animate-pulse"></span>
                {content.availability.status} · {content.availability.location}
            </div>

            <h1 class="mt-10">
                <span class="mask block"><span class="hero-display hero-line block">Frontend</span></span>
                <span class="mask block"><span class="hero-display hero-line block">Engineer<span class="text-[var(--accent)]">.</span></span></span>
                <span class="mask block mt-4"><span class="hero-serif hero-line block text-3xl sm:text-4xl md:text-5xl">building AI-integrated products that ship.</span></span>
            </h1>

            <div class="mt-12 grid gap-10 md:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)] md:items-end">
                <p class="max-w-xl text-lg leading-8 text-[var(--ink-secondary)] hero-fade">
                    {content.hero.bio}
                </p>
                <div class="flex flex-wrap gap-3 md:justify-end hero-fade">
                    <a class="button-primary" href={content.hero.cta.primary.href}>
                        {content.hero.cta.primary.label}
                    </a>
                    <a class="button-secondary" href={content.hero.cta.secondary.href}>
                        {content.hero.cta.secondary.label}
                    </a>
                </div>
            </div>

            <div class="hero-rule mt-16 hero-fade"></div>

            <div class="mt-10 grid grid-cols-2 gap-8 md:grid-cols-4" data-stagger>
                {stats.map((stat) => (
                    <div class="stat-block">
                        <p class="stat-value">
                            <span data-count={stat.value}>{stat.value}</span><span class="acc">{stat.suffix}</span>
                        </p>
                        <p class="stat-label">{stat.label}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- MARQUEE -->
    <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
            {[0, 1].map(() => (
                <>
                    {marqueeItems.map((item) => (
                        <>
                            <span>{item}</span>
                            <span class="acc">✦</span>
                        </>
                    ))}
                </>
            ))}
        </div>
    </div>

    <!-- WORK -->
    <section id="work" class="section">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Selected work</p>
                    <h2 class="section-title">Built, shipped,<br />maintained.</h2>
                </div>
                <span class="section-index hidden md:block">01</span>
            </div>

            <div class="mt-14">
                {content.projects.map((project, i) => (
                    <a class="project-row" href={`/projects/${project.slug}`} data-reveal>
                        <span class="project-row-index">{String(i + 1).padStart(2, "0")}</span>
                        <div class="space-y-3">
                            <h3 class="project-row-title">{project.title}</h3>
                            <p class="max-w-md text-sm leading-6 text-[var(--ink-secondary)]">{project.description}</p>
                        </div>
                        <div class="space-y-3">
                            <div class="flex flex-wrap gap-1.5">
                                {project.tags.map((tag) => (
                                    <span class="pill">{tag}</span>
                                ))}
                            </div>
                            <p class="font-mono text-xs uppercase tracking-[0.16em] text-[var(--ink-muted)]">
                                {project.metrics.map((m) => `${m.value} ${m.label}`).join(" · ")}
                            </p>
                        </div>
                        <span class="project-row-arrow">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                        </span>
                    </a>
                ))}
            </div>

            <div class="mt-20" data-reveal>
                <p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--ink-muted)] mb-6">More builds</p>
                <div class="grid sm:grid-cols-2 lg:grid-cols-4" data-stagger>
                    {content.secondaryProjects.map((project) => (
                        <a class="mini-card group" href={project.href} target="_blank" rel="noreferrer">
                            <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--accent-text)]">{project.category}</p>
                            <h3 class="mt-3 font-display text-base uppercase group-hover:text-[var(--accent)] transition-colors">{project.title}</h3>
                            <p class="mt-2 text-sm leading-6 text-[var(--ink-secondary)]">{project.summary}</p>
                        </a>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="section section-border">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Capabilities</p>
                    <h2 class="section-title">What I<br />work with.</h2>
                    <p class="section-copy">
                        Deep frontend craft, hands-on AI engineering, and enough backend to ship complete products end-to-end.
                    </p>
                </div>
                <span class="section-index hidden md:block">02</span>
            </div>

            <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
                {content.skillCategories.map((category) => (
                    <div class="skill-block">
                        <h3 class="font-mono text-xs font-medium uppercase tracking-[0.18em] text-[var(--ink)]">{category.title}</h3>
                        <ul class="mt-5">
                            {category.tags.map((tag) => (
                                <li class="skill-tag">{tag}</li>
                            ))}
                        </ul>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- EXPERIENCE -->
    <section id="experience" class="section section-border">
        <div class="layout-shell">
            <div class="flex items-end justify-between gap-6" data-reveal>
                <div>
                    <p class="section-eyebrow">Experience</p>
                    <h2 class="section-title">Where I've<br />shipped.</h2>
                </div>
                <span class="section-index hidden md:block">03</span>
            </div>

            <div class="mt-14">
                {content.experience.map((item) => (
                    <div class="xp-row" data-reveal>
                        <p class="xp-period">{item.period}</p>
                        <div>
                            <h3 class="xp-company">{item.company}</h3>
                            <p class="xp-role">{item.role}</p>
                            <p class="mt-4 max-w-2xl text-[15px] leading-7 text-[var(--ink-secondary)]">{item.description}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="section section-border">
        <div class="layout-shell">
            <p class="section-eyebrow" data-reveal>{content.availability.status} · {content.availability.roles.join(" / ")}</p>
            <h2 class="contact-display mt-8" data-reveal>
                Let's ship<br />something<span class="text-[var(--accent)]">.</span>
            </h2>
            <div class="mt-10" data-reveal>
                <a class="contact-email" href={`mailto:${content.contact.email}`}>
                    {content.contact.email}
                </a>
            </div>
            <div class="mt-14 flex flex-wrap items-center gap-6" data-reveal>
                {content.contact.socials.map((social) => (
                    <a
                        class="font-mono text-xs uppercase tracking-[0.2em] text-[var(--ink-secondary)] transition-colors hover:text-[var(--accent)]"
                        href={social.href}
                        target="_blank"
                        rel="noreferrer"
                    >
                        {social.label} ↗
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (!reduced) {
        gsap.timeline({ defaults: { ease: "power3.out" } })
            .from(".hero-line", { yPercent: 110, duration: 0.9, stagger: 0.12 })
            .from(".hero-fade", { y: 24, autoAlpha: 0, duration: 0.7, stagger: 0.1 }, "-=0.45");

        document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
            const target = Number(el.dataset.count);
            gsap.fromTo(
                el,
                { textContent: 0 },
                {
                    textContent: target,
                    duration: 1.4,
                    ease: "power1.out",
                    snap: { textContent: 1 },
                    scrollTrigger: { trigger: el, start: "top 90%" },
                },
            );
        });

        gsap.utils.toArray<HTMLElement>("[data-reveal]").forEach((el) => {
            gsap.from(el, {
                y: 36,
                autoAlpha: 0,
                duration: 0.8,
                ease: "power3.out",
                scrollTrigger: { trigger: el, start: "top 88%" },
            });
        });

        gsap.utils.toArray<HTMLElement>("[data-stagger]").forEach((group) => {
            gsap.from(group.children, {
                y: 24,
                autoAlpha: 0,
                duration: 0.6,
                stagger: 0.08,
                ease: "power2.out",
                scrollTrigger: { trigger: group, start: "top 88%" },
            });
        });

        gsap.to(".marquee-track", {
            xPercent: -50,
            ease: "none",
            duration: 28,
            repeat: -1,
        });
    }
</script>
