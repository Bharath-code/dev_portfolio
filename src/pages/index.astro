---
import Layout from "@/layouts/Layout.astro";
import SectionIntro from "@/components/site/SectionIntro.astro";
import ProjectShowcaseCard from "@/components/site/ProjectShowcaseCard.astro";
import { siteContent } from "@/content/site-content";
import { fetchRepoStatsByUrls } from "@/lib/github";
import booksData from "@/data/books.json";
import { mapBooks, type RawBook } from "@/lib/books";
import { ArrowUpRight, Mail, MapPin, Sparkles } from "lucide-react";

const projectUrls = siteContent.projects.map((project) => project.link);
const repoStatsMap = await fetchRepoStatsByUrls(projectUrls);
const books = mapBooks(booksData as RawBook[])
    .filter((book) => book.status === "recommended")
    .slice(0, 3);

function getStatsForProject(link: string) {
    const match = link.match(/github\.com\/[^/]+\/([^/]+)/);
    if (!match) return undefined;
    const repoName = match[1].replace(/\.git$/, "").toLowerCase();
    return repoStatsMap.get(repoName);
}
---

<Layout
    title="Bharathkumar Palanisamy | Software Engineer"
    description="Software engineer building developer tools, AI-integrated products, and fast, credible web experiences."
>
    <section class="section-shell">
        <div class="shell hero-layout">
            <div class="space-y-8">
                <p class="section-kicker fade-up">
                    Recruiter-first portfolio · open to product engineering roles
                </p>
                <div class="space-y-6">
                    <h1 class="hero-title balance fade-up fade-delay-1">
                        {siteContent.hero.title}
                    </h1>
                    <p class="text-sm font-semibold uppercase tracking-[0.24em] text-[var(--muted-soft)] fade-up fade-delay-1">
                        {siteContent.hero.subtitle}
                    </p>
                    <p class="hero-copy fade-up fade-delay-2">
                        {siteContent.hero.bio}
                    </p>
                </div>

                <div class="flex flex-wrap gap-3 fade-up fade-delay-3">
                    <a class="button-primary" href="#work">See selected work</a>
                    <a class="button-secondary" href="#contact">
                        <Mail className="h-4 w-4" />
                        Start a conversation
                    </a>
                </div>
            </div>

            <aside class="hero-panel fade-up fade-delay-2">
                <div class="flex items-start gap-5">
                    <img
                        src="/profile-pic-2.png"
                        alt="Portrait of Bharathkumar Palanisamy"
                        class="h-24 w-24 rounded-[28px] object-cover"
                        loading="eager"
                    />
                    <div class="space-y-2">
                        <p class="card-kicker">Candidate snapshot</p>
                        <h2 class="font-serif text-3xl leading-none">
                            Bharathkumar Palanisamy
                        </h2>
                        <p class="card-copy text-sm">
                            Software engineer focused on developer tools,
                            full-stack product delivery, and AI-augmented
                            workflows that move faster without cutting corners.
                        </p>
                    </div>
                </div>

                <dl class="mt-8 grid gap-3 sm:grid-cols-2">
                    <div class="metric-row">
                        <dt>Core stack</dt>
                        <dd>Go, TypeScript, React, Node.js</dd>
                    </div>
                    <div class="metric-row">
                        <dt>Focus</dt>
                        <dd>Developer tools, SaaS, AI product workflows</dd>
                    </div>
                    <div class="metric-row">
                        <dt class="inline-flex items-center gap-2">
                            <MapPin className="h-3.5 w-3.5" />
                            Based in
                        </dt>
                        <dd>India · remote-friendly</dd>
                    </div>
                    <div class="metric-row">
                        <dt>Availability</dt>
                        <dd>Open to devtools, full-stack, and AI roles</dd>
                    </div>
                </dl>

                <div class="mt-8 rounded-[24px] border border-[var(--line)] bg-white/50 p-5">
                    <p class="section-kicker">Why this portfolio exists</p>
                    <p class="mt-3 text-sm leading-7 text-[var(--muted)]">
                        To show shipped proof, product taste, and technical
                        range in one place so recruiters can quickly understand
                        both fit and upside.
                    </p>
                </div>
            </aside>
        </div>
    </section>

    <section class="section-shell-tight">
        <div class="shell grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            {siteContent.impactHighlights.map((highlight) => (
                <article class="metric-card content-auto">
                    <strong>{highlight.value}</strong>
                    <span>{highlight.label}</span>
                    <p>{highlight.description}</p>
                </article>
            ))}
        </div>
    </section>

    <section id="work" class="section-shell section-surface">
        <div class="shell space-y-12">
            <SectionIntro
                eyebrow="Selected work"
                title="Products, tools, and systems that show how I solve for both users and engineering teams."
                description="These projects highlight interface craft, technical judgment, and shipping discipline. Each case study is written to be quickly scannable by recruiters and still useful to engineering leaders."
            />

            <div class="grid gap-6 xl:grid-cols-2">
                {siteContent.projects.map((project) => (
                    <ProjectShowcaseCard
                        project={project}
                        githubStats={getStatsForProject(project.link)}
                    />
                ))}
            </div>
        </div>
    </section>

    <section class="section-shell">
        <div class="shell grid gap-8 xl:grid-cols-[minmax(0,1.05fr)_minmax(340px,0.95fr)]">
            <div class="space-y-10">
                <SectionIntro
                    eyebrow="Open to opportunities"
                    title={siteContent.opportunities.headline}
                    description={siteContent.opportunities.summary}
                />

                <div class="grid gap-5 md:grid-cols-3">
                    {siteContent.opportunities.roles.map((role) => (
                        <article class="surface-card content-auto">
                            <div class="space-y-3">
                                <p class="card-kicker">Best-fit role</p>
                                <h3 class="card-title text-[1.65rem]">
                                    {role.title}
                                </h3>
                                <p class="card-copy text-sm">{role.summary}</p>
                            </div>
                        </article>
                    ))}
                </div>
            </div>

            <aside class="surface-card content-auto">
                <p class="card-kicker">Location and team fit</p>
                <div class="space-y-4">
                    {siteContent.opportunities.preferences.map((item) => (
                        <div class="metric-row">
                            <dt>Preference</dt>
                            <dd>{item}</dd>
                        </div>
                    ))}
                </div>
            </aside>
        </div>
    </section>

    <section class="section-shell">
        <div class="shell grid gap-8 xl:grid-cols-[minmax(0,1.15fr)_minmax(320px,0.85fr)]">
            <div class="space-y-10">
                <SectionIntro
                    eyebrow="What I bring"
                    title="A mix of product taste, frontend depth, and delivery focus."
                    description="I’m strongest where product quality and implementation quality have to reinforce each other."
                />

                <div class="grid gap-5 md:grid-cols-2">
                    {siteContent.skillCategories.map((category) => (
                        <article class="surface-card content-auto">
                            <div class="space-y-4">
                                <p class="card-kicker">{category.title}</p>
                                <h3 class="card-title text-[1.8rem]">
                                    {category.description}
                                </h3>
                                <div class="flex flex-wrap gap-2">
                                    {category.tags.map((tag) => (
                                        <span class="pill">{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </article>
                    ))}
                </div>
            </div>

            <aside class="surface-card-dark content-auto">
                <div class="space-y-5">
                    <p class="section-kicker text-[#cfb7a6]">Modern workflow</p>
                    <h2 class="font-serif text-4xl leading-tight">
                        AI is part of my delivery system, not a substitute for
                        engineering judgment.
                    </h2>
                    <p class="text-base leading-7 text-[#d8c8bd]">
                        I use AI where it compounds output: exploration,
                        scaffolding, debugging, test design, and operational
                        automation. The standard stays the same: readable code,
                        durable abstractions, and clear product decisions.
                    </p>
                </div>

                <div class="grid gap-4">
                    {siteContent.aiToolkit.categories.map((category) => (
                        <div class="rounded-[24px] border border-white/10 bg-white/5 p-5">
                            <p class="card-kicker text-[#cfb7a6]">
                                {category.label}
                            </p>
                            <div class="mt-3 flex flex-wrap gap-2">
                                {category.tools.map((tool) => (
                                    <span class="rounded-full border border-white/10 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-[#f4e7dc]">
                                        {tool}
                                    </span>
                                ))}
                            </div>
                        </div>
                    ))}
                </div>
            </aside>
        </div>
    </section>

    <section id="experience" class="section-shell section-surface">
        <div class="shell space-y-12">
            <SectionIntro
                eyebrow="Experience"
                title="Experience in environments where reliability, delivery pace, and trust mattered."
                description="I’ve worked on enterprise platforms and banking software, where software quality is visible in both the UI and the operational outcomes."
            />

            <div class="space-y-5">
                {siteContent.experience.map((item) => (
                    <article class="timeline-item content-auto">
                        <div class="space-y-2">
                            <p class="section-kicker">{item.period}</p>
                            <h3 class="font-serif text-3xl leading-none">
                                {item.company}
                            </h3>
                            <p class="text-base font-semibold text-[var(--ink)]">
                                {item.role}
                            </p>
                        </div>
                        <p class="card-copy">{item.description}</p>
                    </article>
                ))}
            </div>
        </div>
    </section>

    <section class="section-shell">
        <div class="shell space-y-10">
            <SectionIntro
                eyebrow="Other projects"
                title="A wider body of work across CLI tools, SaaS ideas, browser extensions, and educational products."
                description="The flagship projects show depth. This grid shows range and shipping cadence."
            />

            <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
                {siteContent.secondaryProjects.map((project) => (
                    <a
                        class="surface-card content-auto transition-transform duration-200 hover:-translate-y-1"
                        href={project.href}
                        target="_blank"
                        rel="noreferrer"
                    >
                        <div class="space-y-4">
                            <p class="card-kicker">{project.category}</p>
                            <h3 class="card-title text-[1.7rem]">
                                {project.title}
                            </h3>
                            <p class="card-copy text-sm">{project.summary}</p>
                        </div>
                        <span class="resource-link">
                            View repository
                            <ArrowUpRight className="h-4 w-4" />
                        </span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section class="section-shell section-surface">
        <div class="shell grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
            <article class="surface-card content-auto">
                <SectionIntro
                    eyebrow="Writing"
                    title="I write about engineering, architecture, and shipping with intention."
                    description="Articles are where I make my thinking legible: tradeoffs, patterns, and the systems behind good product work."
                />
                <a class="resource-link" href="/blog">
                    Browse articles
                    <ArrowUpRight className="h-4 w-4" />
                </a>
            </article>

            <article class="surface-card content-auto">
                <SectionIntro
                    eyebrow="Reading"
                    title="Books that shape how I think about software, business, and behavior."
                    description="My reading list is part of my operating system. These are a few standouts from the library."
                />
                <div class="grid gap-3">
                    {books.map((book) => (
                        <div class="metric-row">
                            <dt>{book.title}</dt>
                            <dd>{book.author}</dd>
                        </div>
                    ))}
                </div>
                <a class="resource-link" href="/books">
                    Explore the library
                    <ArrowUpRight className="h-4 w-4" />
                </a>
            </article>
        </div>
    </section>

    <section id="contact" class="section-shell">
        <div class="shell">
            <article class="surface-card-dark">
                <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_auto] lg:items-end">
                <div class="space-y-5">
                    <p class="section-kicker text-[#cfb7a6]">
                        Final signal
                    </p>
                    <h2 class="font-serif text-4xl leading-tight md:text-5xl">
                        If you need someone who can build product UI, developer
                        workflows, and AI-assisted features end-to-end, we
                        should talk.
                    </h2>
                    <p class="max-w-2xl text-base leading-7 text-[#d8c8bd]">
                        I’m looking for teams that value shipping, product
                        ownership, and using AI as leverage without lowering the
                        engineering bar.
                    </p>
                </div>

                    <div class="flex flex-col gap-3">
                        <a
                            class="button-primary"
                            href={`mailto:${siteContent.contact.email}`}
                        >
                            <Mail className="h-4 w-4" />
                            {siteContent.contact.email}
                        </a>
                        <a
                            class="button-secondary border-white/15 bg-white/10 text-[#fff7ef]"
                            href="https://linkedin.com/in/bharathkumar-palanisamy"
                            target="_blank"
                            rel="noreferrer"
                        >
                            <Sparkles className="h-4 w-4" />
                            Connect on LinkedIn
                        </a>
                    </div>
                </div>
            </article>
        </div>
    </section>
</Layout>
