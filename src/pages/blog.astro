---
import Layout from "@/layouts/Layout.astro";
import SectionIntro from "@/components/site/SectionIntro.astro";
import PostCard from "@/components/site/PostCard.astro";
import { getLatestPosts } from "@/lib/blog";
import { siteContent } from "@/content/site-content";

const posts = await getLatestPosts(siteContent.blogConfig, 18);
const mediumPosts = posts.filter((post) => post.platform === "Medium");
const devtoPosts = posts.filter((post) => post.platform === "Dev.to");
---

<Layout
    title="Writing | Bharathkumar Palanisamy"
    description="Engineering writing from Bharathkumar Palanisamy on architecture, frontend systems, and practical software delivery."
>
    <section class="section-shell">
        <div class="shell grid gap-8 xl:grid-cols-[minmax(0,1.1fr)_340px] xl:items-end">
            <SectionIntro
                eyebrow="Writing"
                title="I write to make my engineering taste inspectable."
                description="The articles below cover architecture, tooling, and the habits behind reliable shipping. This is where I slow down and explain the decisions, not just the outcomes."
            />

            <aside class="surface-card content-auto">
                <p class="card-kicker">What to expect</p>
                <div class="space-y-3">
                    <p class="card-copy">
                        I focus on practical lessons, implementation details,
                        and patterns that teams can reuse.
                    </p>
                    <p class="card-copy">
                        Medium holds the broader essays. Dev.to carries the
                        more tactical engineering walkthroughs.
                    </p>
                </div>
            </aside>
        </div>
    </section>

    {mediumPosts.length > 0 && (
        <section class="section-shell-tight section-surface">
            <div class="shell space-y-10">
                <SectionIntro
                    eyebrow="Medium"
                    title="Longer-form writing on product, architecture, and engineering clarity."
                />
                <div class="grid gap-6 lg:grid-cols-2">
                    {mediumPosts.map((post) => (
                        <PostCard post={post} />
                    ))}
                </div>
            </div>
        </section>
    )}

    {devtoPosts.length > 0 && (
        <section class="section-shell">
            <div class="shell space-y-10">
                <SectionIntro
                    eyebrow="Dev.to"
                    title="Hands-on technical writing with a stronger implementation bias."
                />
                <div class="grid gap-6 lg:grid-cols-2">
                    {devtoPosts.map((post) => (
                        <PostCard post={post} />
                    ))}
                </div>
            </div>
        </section>
    )}
</Layout>
