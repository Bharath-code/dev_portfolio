---
import Layout from "@/layouts/Layout.astro";
import {
    getAllProjectSlugs,
    getNextProject,
    getProjectBySlug,
} from "@/content/site-content";

export function getStaticPaths() {
    return getAllProjectSlugs().map((slug) => ({
        params: { slug },
    }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug as string);

if (!project) {
    return Astro.redirect("/404");
}

const nextProject = getNextProject(slug as string);
---

<Layout
    title={`${project.title} | Bharathkumar Palanisamy`}
    description={project.description}
>
    <section class="section">
        <div class="layout-shell space-y-10">
            <a class="link-arrow" href="/#work">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
                Back to all projects
            </a>

            <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] lg:items-start">
                <div class="space-y-6">
                    <div class="flex flex-wrap gap-1.5">
                        {project.tags.map((tag) => (
                            <span class="pill">{tag}</span>
                        ))}
                    </div>
                    <h1 class="font-display text-4xl uppercase leading-[1.02] md:text-6xl">
                        {project.title}<span class="text-[var(--accent)]">.</span>
                    </h1>
                    <p class="max-w-2xl text-lg leading-8 text-[var(--ink-secondary)]">{project.description}</p>
                    <ul class="grid gap-3">
                        {project.highlights.map((highlight) => (
                            <li class="flex gap-2 text-base leading-7 text-[var(--ink-secondary)]">
                                <span class="mt-[10px] h-2 w-2 flex-none rounded-full bg-[var(--accent)]"></span>
                                <span>{highlight}</span>
                            </li>
                        ))}
                    </ul>
                </div>

                <aside class="card">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--ink-muted)]">Metrics</p>
                    <dl class="mt-5 grid gap-3">
                        {project.metrics.map((metric) => (
                            <div class="rounded-lg border px-4 py-3" style="border-color: var(--line);">
                                <dt class="metric-label">{metric.label}</dt>
                                <dd class="metric-value">{metric.value}</dd>
                            </div>
                        ))}
                    </dl>
                    <div class="mt-6 flex flex-col gap-3">
                        <a
                            class="button-primary"
                            href={project.link}
                            target="_blank"
                            rel="noreferrer"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3-1 5-3.5 5-7.5 0-3-1.5-5-4-6 .5-1.5 0-3-.5-3.5 0 0-1.5.5-2 2-1-.5-2-.5-3 0-.5-1.5-2-1.5-2-.5 0-3 1.5-3 3.5 0 4 2 6.5 5 7.5a4.8 4.8 0 0 0-1 3.5v4"/><path d="M9 22c-3 0-4-1.5-4-3v-1"/></svg>
                            View on GitHub
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    {nextProject && (
        <section class="section section-border">
            <div class="layout-shell">
                <div class="card-dark">
                    <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
                        <div class="space-y-3">
                            <p class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--accent-text)]">Next project</p>
                            <h2 class="font-display text-2xl uppercase leading-tight md:text-3xl">
                                {nextProject.title}
                            </h2>
                        </div>
                        <a
                            class="button-secondary"
                            href={`/projects/${nextProject.slug}`}
                        >
                            Next project →
                        </a>
                    </div>
                </div>
            </div>
        </section>
    )}
</Layout>