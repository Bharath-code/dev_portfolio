---
import Layout from "@/layouts/Layout.astro";
import SectionIntro from "@/components/site/SectionIntro.astro";
import {
    getAllProjectSlugs,
    getNextProject,
    getProjectBySlug,
} from "@/content/site-content";
import { ArrowLeft, ArrowRight, ArrowUpRight, Github } from "lucide-react";

export function getStaticPaths() {
    return getAllProjectSlugs().map((slug) => ({
        params: { slug },
    }));
}

const { slug } = Astro.params;
const project = getProjectBySlug(slug as string);

if (!project) {
    return Astro.redirect("/404");
}

const nextProject = getNextProject(slug as string);
const spotlight = project.spotlight;

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "SoftwareApplication",
            name: project.title,
            description: project.description,
            applicationCategory: "DeveloperApplication",
            operatingSystem: "Cross-platform",
            author: {
                "@type": "Person",
                name: "Bharathkumar Palanisamy",
                url: "https://www.bharathkumar.dev",
            },
            url: `https://www.bharathkumar.dev/projects/${project.slug}`,
        },
        {
            "@type": "BreadcrumbList",
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    name: "Home",
                    item: "https://www.bharathkumar.dev",
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    name: "Projects",
                    item: "https://www.bharathkumar.dev/#work",
                },
                {
                    "@type": "ListItem",
                    position: 3,
                    name: project.title,
                    item: `https://www.bharathkumar.dev/projects/${project.slug}`,
                },
            ],
        },
    ],
};
---

<Layout
    title={`${project.title} | Bharathkumar Palanisamy`}
    description={project.description}
    ogImage={`/og/${project.slug}.png`}
>
    <script type="application/ld+json" is:inline>
        {JSON.stringify(schema)}
    </script>

    <section class="section-shell">
        <div class="shell space-y-10">
            <a class="resource-link" href="/#work">
                <ArrowLeft className="h-4 w-4" />
                Back to selected work
            </a>

            <div class="grid gap-8 xl:grid-cols-[minmax(0,1.1fr)_340px] xl:items-end">
                <div class="space-y-6">
                    <div class="flex flex-wrap gap-2">
                        {project.badges.map((badge) => (
                            <span class="pill">{badge}</span>
                        ))}
                    </div>
                    <h1 class="hero-title balance text-[3.6rem] md:text-[5.1rem] lg:text-[5.8rem]">
                        {project.title}
                    </h1>
                    <p class="hero-copy max-w-3xl">{project.description}</p>
                </div>

                <aside class="hero-panel">
                    <p class="card-kicker">Quick summary</p>
                    <dl class="mt-6 grid gap-3">
                        {project.metrics.map((metric) => (
                            <div class="metric-row">
                                <dt>{metric.label}</dt>
                                <dd>{metric.value}</dd>
                            </div>
                        ))}
                    </dl>
                    <div class="mt-8 flex flex-wrap gap-3">
                        <a
                            class="button-primary"
                            href={project.link}
                            target="_blank"
                            rel="noreferrer"
                        >
                            <Github className="h-4 w-4" />
                            Open GitHub
                        </a>
                        {spotlight?.sandbox && (
                            <a
                                class="button-secondary"
                                href={spotlight.sandbox.src}
                                target="_blank"
                                rel="noreferrer"
                            >
                                <ArrowUpRight className="h-4 w-4" />
                                Open demo
                            </a>
                        )}
                    </div>
                </aside>
            </div>
        </div>
    </section>

    {spotlight && (
        <>
            <section class="section-shell-tight section-surface">
                <div class="shell space-y-10">
                    <SectionIntro
                        eyebrow="Project spotlight"
                        title={spotlight.headline}
                        description={spotlight.overview}
                    />

                    <div class="grid gap-4 lg:grid-cols-3">
                        {spotlight.outcomes.map((outcome) => (
                            <article class="metric-card">
                                <strong>{outcome.value}</strong>
                                <span>{outcome.label}</span>
                            </article>
                        ))}
                    </div>

                    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_360px]">
                        <div class="surface-card">
                            <p class="card-kicker">Key decisions</p>
                            <ul class="mt-5 space-y-4 text-base leading-7 text-[var(--muted)]">
                                {spotlight.highlights.map((highlight) => (
                                    <li class="flex gap-3">
                                        <span class="mt-3 h-2 w-2 flex-none rounded-full bg-[var(--accent)]"></span>
                                        <span>{highlight}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <aside class="surface-card">
                            <p class="card-kicker">Roles played</p>
                            <div class="mt-5 flex flex-wrap gap-2">
                                {spotlight.roles.map((role) => (
                                    <span class="pill">{role}</span>
                                ))}
                            </div>
                        </aside>
                    </div>
                </div>
            </section>

            {spotlight.walkthrough.length > 0 && (
                <section class="section-shell">
                    <div class="shell space-y-10">
                        <SectionIntro
                            eyebrow="Build walkthrough"
                            title="A closer look at the implementation thinking."
                            description="This is the part for engineering managers and technical reviewers who want signal beyond screenshots."
                        />

                        <div class="space-y-6">
                            {spotlight.walkthrough.map((step, index) => (
                                <article class="surface-card content-auto">
                                    <div class="grid gap-6 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
                                        <div class="space-y-4">
                                            <p class="card-kicker">
                                                Step {index + 1}
                                            </p>
                                            <h2 class="card-title text-[2.2rem]">
                                                {step.label}
                                            </h2>
                                            <p class="card-copy">{step.summary}</p>
                                            <div class="metric-row max-w-xs">
                                                <dt>{step.metricLabel}</dt>
                                                <dd>{step.metricValue}</dd>
                                            </div>
                                        </div>
                                        <pre class="rounded-[28px] border border-[var(--line)] bg-[var(--ink)]/95 p-5 text-sm leading-7 text-[#f6ebdf]"><code>{step.code}</code></pre>
                                    </div>
                                </article>
                            ))}
                        </div>
                    </div>
                </section>
            )}

            <section class="section-shell-tight section-surface">
                <div class="shell">
                    <article class="surface-card">
                        <p class="card-kicker">{spotlight.sandbox.title}</p>
                        <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
                            <p class="card-copy">{spotlight.sandbox.description}</p>
                            <a
                                class="button-primary"
                                href={spotlight.sandbox.src}
                                target="_blank"
                                rel="noreferrer"
                            >
                                Launch external preview
                                <ArrowUpRight className="h-4 w-4" />
                            </a>
                        </div>
                    </article>
                </div>
            </section>
        </>
    )}

    {nextProject && (
        <section class="section-shell">
            <div class="shell">
                <article class="surface-card-dark">
                    <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
                        <div class="space-y-4">
                            <p class="section-kicker text-[#cfb7a6]">Next case study</p>
                            <h2 class="font-serif text-4xl leading-tight">
                                Continue with {nextProject.title}
                            </h2>
                            <p class="max-w-2xl text-base leading-7 text-[#d8c8bd]">
                                Browse the next project to see another slice of
                                my frontend, tooling, and systems work.
                            </p>
                        </div>
                        <a
                            class="button-secondary border-white/15 bg-white/10 text-[#fff7ef]"
                            href={`/projects/${nextProject.slug}`}
                        >
                            Next project
                            <ArrowRight className="h-4 w-4" />
                        </a>
                    </div>
                </article>
            </div>
        </section>
    )}
</Layout>
