---
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

import "@/styles/global.css";
import { siteContent } from "@/content/site-content";
import "@fontsource/archivo-black";
import "@fontsource/manrope";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "@fontsource/instrument-serif";
import "@fontsource/instrument-serif/400-italic.css";

const {
    title,
    description = "Bharathkumar Palanisamy is a software engineer building developer tools, AI-integrated products, and fast, credible web experiences.",
    ogImage = "/og-image.png",
} = Astro.props;

const currentUrl = Astro.url;
const currentPath = currentUrl.pathname;
const currentYear = new Date().getFullYear();

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Person",
            "@id": "https://www.bharathkumar.dev/#person",
            name: "Bharathkumar Palanisamy",
            url: "https://www.bharathkumar.dev",
            image: "https://www.bharathkumar.dev/profile-pic-2.png",
            sameAs: [
                "https://github.com/Bharath-code",
                "https://x.com/iam_pbk",
                "https://linkedin.com/in/bharathkumar-palanisamy",
            ],
            jobTitle: "Software Engineer",
            description,
            knowsAbout: [
                "Developer tools",
                "Frontend engineering",
                "Design systems",
                "TypeScript",
                "React",
                "Astro",
                "Node.js",
                "AI-assisted development",
                "LLM integrations",
            ],
        },
        {
            "@type": "WebSite",
            "@id": "https://www.bharathkumar.dev/#website",
            url: "https://www.bharathkumar.dev",
            name: "Bharathkumar Palanisamy Portfolio",
            inLanguage: "en-US",
            publisher: {
                "@id": "https://www.bharathkumar.dev/#person",
            },
        },
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="software engineer, developer tools, full-stack engineer, Astro portfolio, TypeScript, React, AI engineering, CLI tools"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#f4ecdf" />
        <link rel="icon" type="image/png" href="/profile-pic-2.png?v=1" />
        <link rel="apple-touch-icon" href="/profile-pic-2.png?v=1" />
        <link rel="canonical" href={currentUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={currentUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(ogImage, currentUrl)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={currentUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(ogImage, currentUrl)} />

        <script type="application/ld+json" is:inline>
            {JSON.stringify(jsonLd)}
        </script>
        <title>{title}</title>
    </head>
    <body>
        <a href="#content" class="skip-link">Skip to content</a>
        <div class="page-shell">
            <header class="site-header">
                <div class="shell site-header-inner">
                    <a class="brand-mark" href="/" aria-label="Go to homepage">
                        <span class="brand-mark-badge">BP</span>
                        <span class="hidden sm:inline">Bharathkumar Palanisamy</span>
                    </a>
                    <nav class="site-nav" aria-label="Primary">
                        <div class="site-nav-list">
                            {siteContent.navigation.map((item) => {
                                const isActive =
                                    item.href === currentPath ||
                                    (item.href !== "/" &&
                                        item.href.startsWith(currentPath) &&
                                        currentPath !== "/");

                                return (
                                    <a
                                        class:list={[
                                            "site-nav-link",
                                            isActive && "is-active",
                                        ]}
                                        href={item.href}
                                    >
                                        {item.label}
                                    </a>
                                );
                            })}
                        </div>
                    </nav>
                </div>
            </header>

            <main id="content" class="site-main">
                <slot />
            </main>

            <footer class="site-footer">
                <div class="shell footer-grid">
                    <div class="space-y-4">
                        <p class="section-kicker">Currently open to strong product teams</p>
                        <h2 class="max-w-2xl font-serif text-3xl leading-tight md:text-4xl">
                            I build developer tools, product UI, and AI-powered
                            workflows that teams can rely on in production.
                        </h2>
                        <a class="button-primary" href={`mailto:${siteContent.contact.email}`}>
                            {siteContent.contact.email}
                        </a>
                    </div>
                    <div class="flex flex-col gap-3 text-sm text-[var(--muted)]">
                        {siteContent.contact.socials.map((social) => (
                            <a
                                class="resource-link"
                                href={social.href}
                                target="_blank"
                                rel="noreferrer"
                            >
                                {social.label}
                            </a>
                        ))}
                    </div>
                </div>
                <div class="shell flex flex-col gap-2 border-t py-5 text-sm text-[var(--muted)] md:flex-row md:items-center md:justify-between" style="border-color: var(--line);">
                    <p>© {currentYear} Bharathkumar Palanisamy</p>
                    <p>Built with Astro, purposeful motion, and a smaller JavaScript budget.</p>
                </div>
            </footer>
        </div>
    </body>
</html>
