---
interface Props {
    title: string;
    description?: string;
    ogImage?: string;
}

import "@/styles/global.css";
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/600.css";
import "@fontsource/manrope/700.css";
import "@fontsource/archivo-black";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/instrument-serif";
import "@fontsource/instrument-serif/400-italic.css";
import content from "@/data/site-content.json";

const {
    title,
    description = "Bharathkumar Palanisamy — Frontend Engineer building AI-integrated products, developer tools, and polished web experiences with React, TypeScript, and modern AI tooling.",
    ogImage = "/og-image.png",
} = Astro.props;

const currentUrl = Astro.url;
const currentYear = new Date().getFullYear();

const jsonLd = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Person",
            "@id": "https://www.bharathkumar.dev/#person",
            name: "Bharathkumar Palanisamy",
            url: "https://www.bharathkumar.dev",
            image: "https://www.bharathkumar.dev/profile-pic-2.png",
            sameAs: [
                "https://github.com/Bharath-code",
                "https://x.com/iam_pbk",
                "https://linkedin.com/in/bharathkumar-palanisamy",
            ],
            jobTitle: "Frontend Engineer",
            description,
            knowsAbout: [
                "Frontend engineering",
                "React",
                "Next.js",
                "TypeScript",
                "AI agents",
                "RAG",
                "LLM integration",
                "Developer tools",
                "Go",
                "Node.js",
            ],
        },
        {
            "@type": "WebSite",
            "@id": "https://www.bharathkumar.dev/#website",
            url: "https://www.bharathkumar.dev",
            name: "Bharathkumar Palanisamy",
            inLanguage: "en-US",
            publisher: {
                "@id": "https://www.bharathkumar.dev/#person",
            },
        },
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <meta
            name="keywords"
            content="frontend engineer, React, Next.js, TypeScript, AI agents, RAG, LLM integration, developer tools, portfolio"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#0d0d0b" />
        <link rel="icon" type="image/png" href="/profile-pic-2.png?v=1" />
        <link rel="apple-touch-icon" href="/profile-pic-2.png?v=1" />
        <link rel="canonical" href={currentUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={currentUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={new URL(ogImage, currentUrl)} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:site" content="@iam_pbk" />
        <meta property="twitter:creator" content="@iam_pbk" />
        <meta property="twitter:url" content={currentUrl} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={new URL(ogImage, currentUrl)} />

        <script type="application/ld+json" is:inline>
            {JSON.stringify(jsonLd)}
        </script>
        <title>{title}</title>
    </head>
    <body>
        <a href="#content" class="skip-link">Skip to content</a>
        <div class="page-shell">
            <header class="site-header">
                <div class="layout-shell site-header-inner">
                    <a class="brand-mark" href="/" aria-label="Home">
                        <span class="brand-mark-badge">BP</span>
                        <span class="hidden sm:inline">Bharathkumar</span>
                    </a>
                    <nav class="site-nav hidden md:flex" aria-label="Primary">
                        {content.navigation.map((item) => (
                            <a class="site-nav-link" href={item.href}>
                                {item.label}
                            </a>
                        ))}
                    </nav>
                    <a
                        class="button-primary text-xs md:text-sm"
                        href={`mailto:${content.contact.email}`}
                    >
                        Get in touch
                    </a>
                </div>
            </header>

            <main id="content" class="site-main">
                <slot />
            </main>

            <footer class="site-footer">
                <div class="layout-shell">
                    <div class="grid gap-8 md:grid-cols-[1fr_auto]">
                        <div class="space-y-3">
                            <p class="text-sm font-semibold text-[var(--ink)]">
                                Bharathkumar Palanisamy
                            </p>
                            <p class="max-w-sm text-sm leading-6 text-[var(--ink-secondary)]">
                                Frontend engineer building AI-integrated
                                products and developer tools.
                            </p>
                        </div>
                        <div class="flex flex-col gap-2 text-sm">
                            {content.contact.socials.map((social) => (
                                <a
                                    class="text-[var(--ink-secondary)] transition-colors hover:text-[var(--ink)]"
                                    href={social.href}
                                    target="_blank"
                                    rel="noreferrer"
                                >
                                    {social.label}
                                </a>
                            ))}
                        </div>
                    </div>
                    <div class="mt-8 border-t py-5 text-sm text-[var(--ink-muted)]" style="border-color: var(--line);">
                        &copy; {currentYear} Bharathkumar Palanisamy
                    </div>
                </div>
            </footer>
        </div>
    </body>
</html>